---
// Layout.astro — 모든 페이지에 공통 적용되는 "액자"
interface Props {
  title?: string;
  prev?: { href: string; label: string };
  next?: { href: string; label: string };
}

const { title = 'AI Novice 교육 가이드', prev, next } = Astro.props;

// 페이지 순서 정의 (네비게이션 + active tab 탐지용)
const pages = [
  { href: '/', label: 'Overview', emoji: '🏠' },
  { href: '/00-ai-ml-basics', label: 'AI & ML 기초', emoji: '🌱' },
  { href: '/01-deep-learning', label: '딥러닝 심화', emoji: '🔬' },
  { href: '/02-llm', label: 'LLM 이해', emoji: '🧠' },
  { href: '/03-ai-agents', label: 'AI Agents', emoji: '🤖' },
  { href: '/04-ai-agents-advanced', label: 'AI Agents 실전', emoji: '🎯' },
  { href: '/05-vibe-basic', label: '바이브코딩', emoji: '💻' },
  { href: '/06-vibe-master', label: '바이브코딩 심화', emoji: '🚀' },
  { href: '/07-ai-dev', label: 'AI 개발', emoji: '🛠️' },
  { href: '/08-data-basics', label: 'Data 기초', emoji: '📊' },
  { href: '/09-data-enterprise', label: 'Data 실전', emoji: '🏢' },
  { href: '/10-it-basics', label: 'IT 기초', emoji: '🖥️' },
  { href: '/11-power-platform', label: 'Power Platform', emoji: '⚡' },
];

// 현재 페이지의 인덱스 찾기
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const currentIdx = pages.findIndex(p => p.href === currentPath);
const prevPage = prev || (currentIdx > 0 ? { href: pages[currentIdx - 1].href, label: pages[currentIdx - 1].label } : null);
const nextPage = next || (currentIdx < pages.length - 1 ? { href: pages[currentIdx + 1].href, label: pages[currentIdx + 1].label } : null);
---

<!DOCTYPE html>
<html lang="ko" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Progress Bar -->
  <div class="progress-bar" id="progressBar"></div>

  <!-- Site Logo -->
  <a class="pwc-logo" href="/" style="font-family:var(--display);font-size:.88rem;font-weight:800;color:var(--accent);text-decoration:none;letter-spacing:-.5px">
    AI<span style="color:var(--text-dim);font-weight:400;margin-left:2px">novice</span>
  </a>

  <!-- Search Button -->
  <button class="search-btn" id="searchBtn" title="검색 (Ctrl+K)" style="position:fixed;top:12px;right:60px;z-index:1001;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:6px 14px;font-size:.82rem;color:var(--text-dim);cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .2s" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-dim)'">
    🔍 <span style="font-family:var(--mono);font-size:.72rem;opacity:.6">Ctrl+K</span>
  </button>

  <!-- Search Modal -->
  <div id="searchModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.7);z-index:2000;align-items:flex-start;justify-content:center;padding-top:12vh">
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:16px;width:90%;max-width:600px;max-height:70vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.5)">
      <div style="padding:16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px">
        <span style="font-size:1.1rem">🔍</span>
        <input id="searchInput" type="text" placeholder="챕터, 개념, 키워드 검색..." style="flex:1;background:transparent;border:none;outline:none;font-size:1rem;color:var(--text);font-family:var(--sans)" autocomplete="off">
        <kbd style="font-family:var(--mono);font-size:.7rem;color:var(--text-dim);background:var(--surface);padding:2px 8px;border-radius:4px;border:1px solid var(--border)">ESC</kbd>
      </div>
      <div id="searchResults" style="overflow-y:auto;padding:8px;flex:1;min-height:0"></div>
      <div style="padding:8px 16px;border-top:1px solid var(--border);font-size:.72rem;color:var(--text-dim);text-align:center">
        ↑↓ 탐색 · Enter 이동 · ESC 닫기
      </div>
    </div>
  </div>

  <!-- Theme Toggle -->
  <button class="theme-toggle" id="themeToggle" title="라이트/다크 모드 전환">🌙</button>

  <!-- Navigation Tabs (자동 생성 + active 표시) -->
  <div class="main-tabs" id="mainTabs">
    <div class="main-tabs-inner">
      {pages.map((p) => (
        <a href={p.href} class={`main-tab ${p.href === currentPath ? 'active' : ''}`}>
          <span class="tab-emoji">{p.emoji}</span>{p.label}
        </a>
      ))}
    </div>
  </div>

  <!-- Page Content (각 페이지의 내용이 여기에 들어감) -->
  <slot />

  <!-- Prev / Next Navigation -->
  {(prevPage || nextPage) && (
    <nav style="max-width:920px;margin:0 auto;padding:2rem 1.5rem 1rem;display:flex;justify-content:space-between;gap:1rem;">
      {prevPage ? (
        <a href={prevPage.href} style="display:flex;align-items:center;gap:.5rem;padding:.7rem 1.2rem;border:1px solid var(--border);border-radius:10px;color:var(--text-dim);text-decoration:none;font-size:.88rem;transition:all .3s" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-dim)'">
          ← {prevPage.label}
        </a>
      ) : <div />}
      {nextPage ? (
        <a href={nextPage.href} style="display:flex;align-items:center;gap:.5rem;padding:.7rem 1.2rem;border:1px solid var(--border);border-radius:10px;color:var(--text-dim);text-decoration:none;font-size:.88rem;transition:all .3s;margin-left:auto" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-dim)'">
          {nextPage.label} →
        </a>
      ) : null}
    </nav>
  )}

  <!-- Footer -->
  <footer class="footer">
    <div class="fl">AI와 함께하는 새로운 업무 방식 🚀</div>
    <div>AI Education · AI Agents · 바이브코딩 · Power Platform</div>
  </footer>

  <!-- Scroll to Top -->
  <button class="scroll-top" id="scrollTop">↑</button>
</body>
</html>

<!-- Global Styles -->
<style is:global>
  @import '../styles/global.css';
</style>

<!-- Global Scripts -->
<script>
  // Theme Toggle
  function toggleTheme() {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    html.setAttribute('data-theme', next);
    const btn = document.getElementById('themeToggle');
    if (btn) btn.textContent = next === 'light' ? '☀️' : '🌙';
    localStorage.setItem('theme', next);
  }

  // Load saved theme
  const saved = localStorage.getItem('theme');
  if (saved === 'light') {
    document.documentElement.setAttribute('data-theme', 'light');
    const btn = document.getElementById('themeToggle');
    if (btn) btn.textContent = '☀️';
  }

  // Theme toggle click
  document.getElementById('themeToggle')?.addEventListener('click', toggleTheme);

  // Scroll to top
  document.getElementById('scrollTop')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Progress bar + scroll-top visibility
  window.addEventListener('scroll', () => {
    const s = document.documentElement.scrollTop;
    const h = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const bar = document.getElementById('progressBar');
    const topBtn = document.getElementById('scrollTop');
    if (bar) bar.style.width = (s / h * 100) + '%';
    if (topBtn) topBtn.classList.toggle('visible', s > 500);
  });

  // ─── Hash anchor scroll: reveal target and scroll on page load ───
  function scrollToHash() {
    const hash = window.location.hash;
    if (!hash) return;
    const target = document.getElementById(hash.substring(1));
    if (!target) return;

    // Force the target AND all its ancestors with .reveal to become visible
    let el: HTMLElement | null = target;
    while (el) {
      if (el.classList.contains('reveal')) el.classList.add('visible');
      el = el.parentElement;
    }
    // Also reveal siblings/children within the same section
    target.querySelectorAll('.reveal').forEach(child => child.classList.add('visible'));

    // Scroll after a short delay to let layout settle
    setTimeout(() => {
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  }

  // Run on page load
  scrollToHash();
  // Also handle in-page hash changes (e.g., from search)
  window.addEventListener('hashchange', scrollToHash);

  // Reveal on scroll — IntersectionObserver with fail-safe
  // Note: threshold 0 + positive rootMargin ensures large blocks also trigger reliably.
  // Large reveal blocks that fully fill the viewport could previously stay hidden if
  // threshold/rootMargin combined kept isIntersecting=false at initial paint.
  const revealEls = document.querySelectorAll('.reveal, .diagram, .compare-card, .callout, .quote-block');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((x) => {
      if (x.isIntersecting) {
        x.target.classList.add('visible');
        obs.unobserve(x.target);
      }
    });
  }, { threshold: 0, rootMargin: '0px 0px 200px 0px' });
  revealEls.forEach((el) => obs.observe(el));

  // Fail-safe 1: make any reveal element already within the initial viewport visible immediately,
  // so slow/missed observer callbacks never leave content blank.
  const vh = window.innerHeight || document.documentElement.clientHeight;
  revealEls.forEach((el) => {
    const r = el.getBoundingClientRect();
    if (r.top < vh + 200) el.classList.add('visible');
  });

  // Fail-safe 2: after 1.5s, force everything still-hidden above the fold to visible.
  // This handles edge cases where IntersectionObserver never fires (e.g., devtools, zoom glitches).
  setTimeout(() => {
    document.querySelectorAll('.reveal:not(.visible), .diagram:not(.visible), .compare-card:not(.visible), .callout:not(.visible), .quote-block:not(.visible)').forEach((el) => {
      const r = el.getBoundingClientRect();
      if (r.top < (window.innerHeight || 0) + 400) el.classList.add('visible');
    });
  }, 1500);

  // ─── Search functionality ───
  let searchIndex: Array<{url:string;part:string;title:string;snippet:string}> = [];
  let searchSelectedIdx = -1;

  async function loadSearchIndex() {
    if (searchIndex.length > 0) return;
    try {
      const res = await fetch('/search-index.json');
      searchIndex = await res.json();
    } catch (e) { console.warn('Search index load failed', e); }
  }

  function openSearch() {
    const modal = document.getElementById('searchModal') as HTMLElement | null;
    const input = document.getElementById('searchInput') as HTMLInputElement | null;
    if (!modal || !input) return;
    modal.style.display = 'flex';
    input.value = '';
    input.focus();
    searchSelectedIdx = -1;
    const results = document.getElementById('searchResults');
    if (results) results.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text-dim);font-size:.85rem">검색어를 입력하세요</div>';
    loadSearchIndex();
  }

  function closeSearch() {
    const modal = document.getElementById('searchModal') as HTMLElement | null;
    if (modal) modal.style.display = 'none';
  }

  function renderResults(query: string) {
    const results = document.getElementById('searchResults');
    if (!results || !query.trim()) {
      if (results) results.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text-dim);font-size:.85rem">검색어를 입력하세요</div>';
      return;
    }

    const q = query.toLowerCase();
    const matched = searchIndex.filter(item =>
      item.title.toLowerCase().includes(q) ||
      item.part.toLowerCase().includes(q) ||
      item.snippet.toLowerCase().includes(q)
    ).slice(0, 20);

    if (matched.length === 0) {
      results.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--text-dim);font-size:.85rem">결과 없음</div>';
      return;
    }

    searchSelectedIdx = 0;
    results.innerHTML = matched.map((item, i) => {
      const escaped = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const highlighted = item.title.replace(new RegExp('(' + escaped + ')', 'gi'), '<mark style="background:var(--accent);color:#000;border-radius:2px;padding:0 2px">$1</mark>');
      return '<a href="' + item.url + '" class="search-result-item" data-idx="' + i + '" style="display:block;padding:10px 14px;border-radius:8px;text-decoration:none;color:var(--text);transition:background .15s;' + (i === 0 ? 'background:var(--surface)' : '') + '">' +
        '<div style="font-size:.88rem;font-weight:600;line-height:1.5">' + highlighted + '</div>' +
        '<div style="font-size:.72rem;color:var(--text-dim);margin-top:2px">' + item.part + (item.snippet ? ' · ' + item.snippet.substring(0, 60) + '...' : '') + '</div>' +
      '</a>';
    }).join('');
  }

  document.getElementById('searchBtn')?.addEventListener('click', openSearch);
  document.getElementById('searchModal')?.addEventListener('click', (e: MouseEvent) => {
    if (e.target === e.currentTarget) closeSearch();
  });

  document.getElementById('searchInput')?.addEventListener('input', (e: Event) => {
    const target = e.target as HTMLInputElement;
    renderResults(target.value);
  });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
      return;
    }
    if (e.key === 'Escape') { closeSearch(); return; }

    const modal = document.getElementById('searchModal') as HTMLElement | null;
    if (!modal || modal.style.display !== 'flex') return;

    const items = document.querySelectorAll<HTMLAnchorElement>('.search-result-item');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      searchSelectedIdx = Math.min(searchSelectedIdx + 1, items.length - 1);
      items.forEach((el, i) => { el.style.background = i === searchSelectedIdx ? 'var(--surface)' : 'transparent'; });
      items[searchSelectedIdx]?.scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      searchSelectedIdx = Math.max(searchSelectedIdx - 1, 0);
      items.forEach((el, i) => { el.style.background = i === searchSelectedIdx ? 'var(--surface)' : 'transparent'; });
      items[searchSelectedIdx]?.scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'Enter' && searchSelectedIdx >= 0) {
      e.preventDefault();
      const link = items[searchSelectedIdx];
      if (link) {
        closeSearch();
        navigateToResult(link.href);
      }
    }
  });

  // Navigate to search result — handles same-page anchor scrolling
  function navigateToResult(url: string) {
    const parsed = new URL(url, window.location.origin);
    const currentPath = window.location.pathname.replace(/\/$/, '');
    const targetPath = parsed.pathname.replace(/\/$/, '');
    const hash = parsed.hash;

    if (currentPath === targetPath && hash) {
      // Same page — reveal + scroll to anchor
      const el = document.getElementById(hash.substring(1));
      if (el) {
        // Reveal target and ancestors
        let node: HTMLElement | null = el;
        while (node) {
          if (node.classList.contains('reveal')) node.classList.add('visible');
          node = node.parentElement;
        }
        el.querySelectorAll('.reveal').forEach(child => child.classList.add('visible'));
        window.history.pushState(null, '', hash);
        setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      }
    } else {
      // Different page — navigate
      window.location.href = url;
    }
  }

  // Also handle click on search results (not just Enter)
  document.getElementById('searchResults')?.addEventListener('click', (e: MouseEvent) => {
    const target = (e.target as HTMLElement).closest<HTMLAnchorElement>('.search-result-item');
    if (target) {
      e.preventDefault();
      closeSearch();
      navigateToResult(target.href);
    }
  });

  // Active tab highlighting is handled server-side in Astro frontmatter

  // ─── Tab navigation: horizontal scroll UX ───
  // Problem: With 10 tabs, the rightmost tabs were clipped on PC and users
  // couldn't access them (no obvious horizontal scrollbar, no wheel→horizontal mapping).
  // Solution: (1) auto-scroll active tab into center on load,
  //           (2) wheel scroll → horizontal,
  //           (3) edge fade hint when overflow exists.
  const tabsWrap = document.getElementById('mainTabs');
  const tabsInner = tabsWrap?.querySelector<HTMLElement>('.main-tabs-inner');
  if (tabsWrap && tabsInner) {
    // (1) Center the active tab on initial load
    const activeTab = tabsInner.querySelector<HTMLElement>('.main-tab.active');
    if (activeTab) {
      const containerWidth = tabsInner.clientWidth;
      const target = activeTab.offsetLeft - (containerWidth / 2) + (activeTab.offsetWidth / 2);
      tabsInner.scrollLeft = Math.max(0, target);
    }

    // (2) Map vertical wheel to horizontal scroll
    tabsInner.addEventListener('wheel', (e: WheelEvent) => {
      // Only intercept when there's actual horizontal overflow
      if (tabsInner.scrollWidth > tabsInner.clientWidth) {
        // Use deltaY if user is scrolling vertically (mouse wheel or trackpad)
        // deltaX is preserved if already horizontal (mac trackpad)
        if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
          e.preventDefault();
          tabsInner.scrollLeft += e.deltaY;
        }
      }
    }, { passive: false });

    // (3) Toggle edge fade hints based on scroll position
    const updateOverflowHints = () => {
      const max = tabsInner.scrollWidth - tabsInner.clientWidth;
      tabsWrap.classList.toggle('has-overflow-left', tabsInner.scrollLeft > 4);
      tabsWrap.classList.toggle('has-overflow-right', tabsInner.scrollLeft < max - 4);
    };
    updateOverflowHints();
    tabsInner.addEventListener('scroll', updateOverflowHints, { passive: true });
    window.addEventListener('resize', updateOverflowHints);
  }
</script>

<script is:inline>
  // Inline script: Runs before page render to prevent flash
  (function() {
    const saved = localStorage.getItem('theme');
    if (saved === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
    }
  })();
</script>
